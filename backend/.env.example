# Copy this file to .env and adjust values for your environment.
# Never commit the real .env file to version control.

FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=change-me-in-production

REQUEST_TIMEOUT=10
MAX_RETRIES=3

MAX_CRAWL_URLS=50
CRAWL_DEPTH=3

# Path to your trained scikit-learn model (joblib format)
# If the file doesn't exist the scanner uses a rule-based fallback
MODEL_PATH=data/models/vuln_model.joblib

REPORTS_DIR=data/scan_reports
LOG_LEVEL=INFO
